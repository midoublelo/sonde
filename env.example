# TfL API key (optional). Without it you're capped at 50 requests/hour, which
# is plenty for a 15-30 min polling interval. Register at:
# https://api-portal.tfl.gov.uk/
TFL_APP_KEY=

# OpenWeatherMap API key (required for weather ingestion). Free tier is
# 60 calls/min and 1,000,000 calls/month - polling every 15 min uses a
# tiny fraction of that. Register at:
# https://home.openweathermap.org/users/sign_up
OPENWEATHER_API_KEY=

# SQLite by default. Swap to a Postgres URL later without changing any code
# that uses src/storage/db.py.
DATABASE_URL=sqlite:///data/tube.db
